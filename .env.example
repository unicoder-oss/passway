# ============================================================
#  Passway — Environment Configuration
#  Скопируйте этот файл в .env и заполните все значения
# ============================================================

# ----------------------------------------------------------
#  Приложение
# ----------------------------------------------------------
APP_NAME="Passway"
APP_ENV=development         # production | development
APP_URL=http://localhost:8000 # Без завершающего слэша. В production используйте HTTPS URL
APP_DEBUG=true              # true только в development
APP_LOCALE=ru               # ru | en
APP_TIMEZONE=UTC

# ----------------------------------------------------------
#  База данных
# ----------------------------------------------------------
DB_DRIVER=sqlite            # pgsql | sqlite

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=passway
DB_USER=passway
DB_PASS=changeme_strong_password
DB_SSLMODE=require           # disable | require | verify-full (рекомендован verify-full в prod)

# SQLite (только для разработки)
DB_SQLITE_PATH=storage/passway.db

# ----------------------------------------------------------
#  Шифрование
#  ВНИМАНИЕ: master key НИКОГДА не хранится в БД
#  Генерируется командой: php install.php
#  В production — передавать через переменную окружения ОС или секрет оркестратора
# ----------------------------------------------------------
# 32 байта в hex (64 символа), например: php -r "echo bin2hex(random_bytes(32));"
MASTER_KEY=

# ----------------------------------------------------------
#  Сессии
# ----------------------------------------------------------
SESSION_TTL=86400            # Время жизни сессии в секундах (24 часа)
SESSION_COOKIE_NAME=passway_session
SESSION_COOKIE_SECURE=false  # true в production за reverse proxy / HTTPS
SESSION_COOKIE_SAMESITE=Strict

# ----------------------------------------------------------
#  Режим развёртывания
#  Устанавливается один раз при первоначальной настройке
# ----------------------------------------------------------
DEPLOY_MODE=                 # team | solo — заполняется после /setup

# ----------------------------------------------------------
#  Rate Limiting
# ----------------------------------------------------------
RATE_LIMIT_API=100           # Запросов в минуту для API (на IP)
RATE_LIMIT_AUTH=20           # Запросов в минуту для эндпоинтов аутентификации

# ----------------------------------------------------------
#  WebAuthn / Passkeys
# ----------------------------------------------------------
WEBAUTHN_RP_ID=localhost            # Должен совпадать с доменом APP_URL
WEBAUTHN_RP_NAME="Passway"
WEBAUTHN_ORIGIN=http://localhost:8000

# ----------------------------------------------------------
#  Логирование
# ----------------------------------------------------------
LOG_CHANNEL=file             # file | stderr
LOG_LEVEL=info               # debug | info | warning | error
LOG_PATH=storage/logs/passway.log
LOG_RETENTION_DAYS=90

# ----------------------------------------------------------
#  Cron / Планировщик
# ----------------------------------------------------------
SCHEDULER_SECRET=            # Случайный токен для защиты /cron эндпоинта

# ----------------------------------------------------------
#  Первоначальная настройка (очищается после setup)
# ----------------------------------------------------------
SETUP_TOKEN_PATH=storage/setup_token.txt
