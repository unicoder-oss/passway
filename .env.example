# ============================================================
#  Passway — Environment Configuration
#  Copy this file to .env and fill in all values
# ============================================================

# ----------------------------------------------------------
#  Application
# ----------------------------------------------------------
APP_NAME="Passway"
APP_ENV=development         # production | development
APP_URL=http://localhost:8000 # No trailing slash. Use an HTTPS URL in production
APP_DEBUG=true              # true only in development
APP_LOCALE=ru               # ru | en
APP_TIMEZONE=UTC

# ----------------------------------------------------------
#  Database
# ----------------------------------------------------------
DB_DRIVER=sqlite            # pgsql | sqlite

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=passway
DB_USER=passway
DB_PASS=changeme_strong_password
DB_SSLMODE=require           # disable | require | verify-full (verify-full recommended in prod)

# SQLite (development only)
DB_SQLITE_PATH=storage/passway.db

# ----------------------------------------------------------
#  Encryption
#  WARNING: the master key is NEVER stored in the database
#  Generated by running: php install.php
#  In production, provide it through an OS environment variable or orchestrator secret
# ----------------------------------------------------------
# 32 bytes in hex (64 characters), for example: php -r "echo bin2hex(random_bytes(32));"
MASTER_KEY=

# ----------------------------------------------------------
#  Sessions
# ----------------------------------------------------------
SESSION_TTL=86400            # Session lifetime in seconds (24 hours)
SESSION_COOKIE_NAME=passway_session
SESSION_COOKIE_SECURE=false  # true in production behind a reverse proxy / HTTPS
SESSION_COOKIE_SAMESITE=Strict

# ----------------------------------------------------------
#  Deployment Mode
#  Set once during initial setup
# ----------------------------------------------------------
DEPLOY_MODE=                 # team | solo - filled after /setup

# ----------------------------------------------------------
#  Rate Limiting
# ----------------------------------------------------------
RATE_LIMIT_API=100           # Requests per minute for API (per IP)
RATE_LIMIT_AUTH=20           # Requests per minute for authentication endpoints

# ----------------------------------------------------------
#  WebAuthn / Passkeys
# ----------------------------------------------------------
WEBAUTHN_RP_ID=localhost            # Must match the APP_URL domain
WEBAUTHN_RP_NAME="Passway"
WEBAUTHN_ORIGIN=http://localhost:8000

# ----------------------------------------------------------
#  Logging
# ----------------------------------------------------------
LOG_CHANNEL=file             # file | stderr
LOG_LEVEL=info               # debug | info | warning | error
LOG_PATH=storage/logs/passway.log
LOG_RETENTION_DAYS=90

# ----------------------------------------------------------
#  Cron / Scheduler
# ----------------------------------------------------------
SCHEDULER_SECRET=            # Random token to protect the /cron endpoint

# ----------------------------------------------------------
#  Initial Setup (cleared after setup)
# ----------------------------------------------------------
SETUP_TOKEN_PATH=storage/setup_token.txt
